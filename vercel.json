{
  "rewrites": [
    { "source": "/env/recommend/:modules", "destination": "/api/env/recommend/:modules" },
    { "source": "/recommend/:modules", "destination": "/api/env/recommend/:modules" },
    { "source": "/env/:modules", "destination": "/api/env/:modules" },
    { "source": "/:modules", "destination": "/api/env/:modules" }
  ],
  "functions": {
    "api/env/[modules].js": {
      "includeFiles": "modules/**"
    },
    "api/modules.js": {
      "includeFiles": "modules/**"
    },
    "api/env/recommend/[modules].js": {
      "includeFiles": "modules/**"
    }
  }
}
